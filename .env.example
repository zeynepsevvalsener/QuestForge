# Root-level env used by docker-compose. Copy to .env and fill in values.
# (Backend-specific reference lives in backend/.env.example.)

# --- Postgres (used by docker-compose to provision the DB) ---
POSTGRES_USER=questforge
POSTGRES_PASSWORD=questforge
POSTGRES_DB=questforge

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- AI provider (OpenAI, must support tool use / function calling) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# --- CORS (allowed frontend origins, comma-separated) ---
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
