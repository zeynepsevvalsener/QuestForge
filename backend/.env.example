# --- Database ---
# Local Docker default (matches docker-compose service name "postgres").
DATABASE_URL=postgresql+psycopg2://questforge:questforge@postgres:5432/questforge

# --- Auth ---
# Use a long, random string in production.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- AI provider (OpenAI, supports function calling / tool use) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# --- Agent loop ---
MAX_TOOL_ROUNDS=5
